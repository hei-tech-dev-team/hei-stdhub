PORT=3001
DATABASE_URL=postgresql://user@/db_name

JWT_SECRET=change-me-to-a-random-string
CLIENT_URL=http://localhost:5173

# Flask-Mail microservice URL (Node backend calls this)
FLASKMAIL_URL=http://localhost:5050

# Email — easiest production path (Resend)
# RESEND_API_KEY=re_...
# RESEND_FROM=HEI STDhub <onboarding@resend.dev>

# SMTP Gmail — used by Flask-Mail and Node fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_PORT=465
# SMTP_SECURE=true   # décommente si port 465 (SSL)
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre-mot-de-passe-application
SMTP_FROM="HEI STDhub <stdhub.admin@gmail.com>"

# VAPID — notifications push (générées automatiquement si absentes)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
