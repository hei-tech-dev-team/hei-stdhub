# Backend example env for HEI STDhub
# Copy to .env and fill secrets (never commit real secrets)

NODE_ENV=development
PORT=3001

# Database connection (Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/stdhub

# JWT secret (set a secure value for production)
JWT_SECRET=change-me-to-a-secure-random-string

# Frontend URL (used for CORS and emails)
CLIENT_URL=http://localhost:5173
# Optional alternative name used in some places
FRONTEND_URL=http://localhost:5173

# Backend public URL (used by production keep-alive ping)
# BACKEND_URL=https://api.your-domain.example

# Cloudinary (optional) - enable with CLOUDINARY_ENABLED=true
CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push VAPID keys (auto-generated at runtime if missing)
# Persist these to avoid key rotation on each restart in production
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Socket / request tuning (optional)
REQUEST_TIMEOUT=30000
SOCKET_PING_TIMEOUT=20000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_BUFFER=1048576
SOCKET_DEFLATE_THRESHOLD=1024
MAX_ONLINE_USERS=5000

# Email (SMTP) settings — OR use Resend API
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HEI STDhub <no-reply@hei-stdhub.local>"
SMTP_SECURE=false

# Legacy / alternative env names supported by mailer
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
EMAIL_SECURE=false

# Resend (https://resend.com) optional fallback
RESEND_API_KEY=
RESEND_FROM="HEI STDhub <onboarding@resend.dev>"

# Mail timeouts
EMAIL_TIMEOUT_MS=10000
RESEND_TIMEOUT_MS=10000

# Production tips:
# - Keep secrets out of git. Use your deployment platform secret manager.
# - Set JWT_SECRET, DATABASE_URL and CLIENT_URL for the server to start (required).
# - If you enable CLOUDINARY_ENABLED=true, fill the CLOUDINARY_* variables.
# - To persist VAPID keys, generate them locally (or let the app generate then copy the values here).
