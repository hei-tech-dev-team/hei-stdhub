# ─── Environment ──────────────────────
NODE_ENV=development

# ─── Server ───────────────────────────
PORT=3001

# ─── Google ───────────────────────────
GOOGLE_API_KEY=

# ─── Database (REQUIRED) ──────────────
DATABASE_URL=postgresql://user:password@localhost:5432/hei_stdhub

# ─── JWT (REQUIRED) ───────────────────
JWT_SECRET=your-secret-key-here

# ─── Frontend URL (REQUIRED) ──────────
CLIENT_URL=http://localhost:5173

# ─── Email — SMTP (Gmail / other) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre.email@gmail.com
SMTP_PASS=app-password-here
SMTP_FROM=HEI STDhub <stdhub.admin@gmail.com>

# ─── Email — Resend (alternative) ─────
# RESEND_API_KEY=re_...
# RESEND_FROM=HEI STDhub <onboarding@resend.dev>

# ─── Cloudinary (optional) ────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ─── VAPID (push notifications) ───────
# Auto-generated at runtime if missing
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ─── Socket.io tuning ─────────────────
SOCKET_PING_TIMEOUT=20000
SOCKET_PING_INTERVAL=25000
SOCKET_MAX_BUFFER=1048576
SOCKET_DEFLATE_THRESHOLD=1024

# ─── Rate limiting ────────────────────
MAX_ONLINE_USERS=5000
REQUEST_TIMEOUT=30000
