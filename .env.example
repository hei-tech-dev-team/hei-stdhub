# ─── Google ───────────────────────────
GOOGLE_API_KEY=

# ─── Base de données ──────────────────
DATABASE_URL=postgres://user:password@localhost:5432/hei_stdhub

# ─── JWT ──────────────────────────────
JWT_SECRET=your-secret-key-here

# ─── Email (mot de passe oublié) ─────
# Option A — Resend (API)
RESEND_API_KEY=re_...
RESEND_FROM=HEI STDhub <onboarding@resend.dev>

# Option B — SMTP (Gmail / autre)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=le-mot-de-passe-d-application
SMTP_FROM=HEI STDhub <votre.email@gmail.com>

# ─── Frontend URL (requis) ────────────
CLIENT_URL=http://localhost:5173

# ─── Cloudinary (optionnel) ───────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── VAPID (push notifications) ───────
# Généré automatiquement si absent
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
